generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PayrollJobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  PAUSED
}

enum PayrollItemStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model PayrollJob {
  id                String           @id @default(uuid()) @db.Uuid
  employerAccountId String           @db.Uuid
  status            PayrollJobStatus @default(QUEUED)
  totalItems        Int
  processedItems    Int              @default(0)
  failedItems       Int              @default(0)
  checkpoint        Int              @default(0)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  items PayrollItem[]

  @@index([employerAccountId])
}

model PayrollItem {
  id                String            @id @default(uuid()) @db.Uuid
  jobId             String            @db.Uuid
  employeeAccountId String            @db.Uuid
  amount            Decimal           @db.Decimal(20, 2)
  currency          String
  status            PayrollItemStatus @default(PENDING)
  transactionId     String?           @db.Uuid
  error             String?
  createdAt         DateTime          @default(now())

  job PayrollJob @relation(fields: [jobId], references: [id])

  @@index([jobId])
}
